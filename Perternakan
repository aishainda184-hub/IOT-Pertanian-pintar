#define BLYNK_TEMPLATE_ID "TMPLxxxx"
#define BLYNK_TEMPLATE_NAME "Peternakan Pintar"
#define BLYNK_AUTH_TOKEN "YourAuthToken"

#include <ESP8266WiFi.h>
#include <BlynkSimpleEsp8266.h>
#include <DHT.h>

char ssid[] = "WiFi";
char pass[] = "Password";

#define DHTPIN D4
#define DHTTYPE DHT11

#define TRIG_PIN D5
#define ECHO_PIN D6

#define LED_PIN D7

DHT dht(DHTPIN, DHTTYPE);

BlynkTimer timer;

void monitoring() {

  float suhu = dht.readTemperature();
  float hum = dht.readHumidity();

  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);

  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);

  digitalWrite(TRIG_PIN, LOW);

  long duration = pulseIn(ECHO_PIN, HIGH);
  float jarak = duration * 0.034 / 2;

  Blynk.virtualWrite(V0, suhu);
  Blynk.virtualWrite(V1, hum);
  Blynk.virtualWrite(V2, jarak);

  if (suhu > 30) {
    digitalWrite(LED_PIN, HIGH);
    Blynk.logEvent("suhu_tinggi",
                   "Suhu kandang terlalu tinggi");
  }
  else {
    digitalWrite(LED_PIN, LOW);
  }

  if (jarak > 15) {
    Blynk.logEvent("pakan_habis",
                   "Pakan hampir habis");
  }
}

void setup() {
  Serial.begin(115200);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  pinMode(LED_PIN, OUTPUT);

  dht.begin();

  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  timer.setInterval(2000L, monitoring);
}

void loop() {
  Blynk.run();
  timer.run();
}
