#define BLYNK_TEMPLATE_ID "TMPLxxxx"
#define BLYNK_TEMPLATE_NAME "Peternakan Pintar"
#define BLYNK_AUTH_TOKEN "YourAuthToken"

#include <ESP8266WiFi.h>
#include <BlynkSimpleEsp8266.h>
#include <DHT.h>
#include <Servo.h>

char ssid[] = "WiFi";
char pass[] = "Password";

#define DHTPIN D4
#define DHTTYPE DHT11

#define TRIG_PIN D5
#define ECHO_PIN D6

#define LED_PIN D7
#define SERVO_PIN D1

DHT dht(DHTPIN, DHTTYPE);
Servo servoPakan;

BlynkTimer timer;

void monitoring() {

  float suhu = dht.readTemperature();
  float hum = dht.readHumidity();

  digitalWrite(TRIG_PIN, LOW);
  delayMicroseconds(2);

  digitalWrite(TRIG_PIN, HIGH);
  delayMicroseconds(10);

  digitalWrite(TRIG_PIN, LOW);

  long duration = pulseIn(ECHO_PIN, HIGH);
  float jarak = duration * 0.034 / 2;

  Blynk.virtualWrite(V0, suhu);
  Blynk.virtualWrite(V1, hum);
  Blynk.virtualWrite(V2, jarak);

  Serial.print("Suhu : ");
  Serial.print(suhu);
  Serial.print(" C | Kelembapan : ");
  Serial.print(hum);
  Serial.print(" % | Jarak : ");
  Serial.print(jarak);
  Serial.println(" cm");

  // LED menyala jika suhu tinggi
  if (suhu > 30) {
    digitalWrite(LED_PIN, HIGH);

    Blynk.logEvent(
      "suhu_tinggi",
      "Suhu kandang terlalu tinggi"
    );
  } else {
    digitalWrite(LED_PIN, LOW);
  }

  // Servo bergerak jika pakan hampir habis
  if (jarak > 15) {

    servoPakan.write(90);

    Blynk.logEvent(
      "pakan_habis",
      "Pakan hampir habis"
    );

  } else {

    servoPakan.write(0);
  }
}

void setup() {

  Serial.begin(115200);

  pinMode(TRIG_PIN, OUTPUT);
  pinMode(ECHO_PIN, INPUT);

  pinMode(LED_PIN, OUTPUT);

  dht.begin();

  servoPakan.attach(SERVO_PIN);
  servoPakan.write(0);

  Blynk.begin(
    BLYNK_AUTH_TOKEN,
    ssid,
    pass
  );

  timer.setInterval(
    2000L,
    monitoring
  );
}

void loop() {
  Blynk.run();
  timer.run();
}
